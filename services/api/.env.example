# --- Claude provider ---
# Required for live responses. If unset, the API uses the built-in stub client
# (safe default: no spend, no crash, tests stay green).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=16000
# Optional; a sensible default is used when blank.
CLAUDE_SYSTEM_PROMPT=
# "off" (default) or "adaptive"
CLAUDE_THINKING=off

# --- Per-user safety limits ---
CLAUDE_MAX_CONCURRENT_PER_USER=3
CLAUDE_RATE_LIMIT_MAX=20
CLAUDE_RATE_LIMIT_WINDOW_MS=60000

# --- Upstream resilience ---
CLAUDE_RETRY_MAX_ATTEMPTS=3
CLAUDE_RETRY_BASE_MS=500

# --- Identity / proxy ---
# Only enable behind a trusted proxy. Default false (uses socket IP).
TRUST_PROXY_HEADER=false

# --- Server (existing; optional overrides) ---
# PORT=4100
# DB_PATH=
# NODE_ENV=development